# Copy this file to .env and fill in local-only secrets.
# Nitter also accepts these values from your shell environment.

# Oxylabs residential/datacenter proxy endpoint.
# Use URL-encoding for special characters in the username or password.
# Example shape: http://customer-USER:PASSWORD@pr.oxylabs.io:7777
NITTER_PROXY=

# Add an Oxylabs sessid value per Twitter/X account so each account gets a
# separate sticky residential proxy identity.
NITTER_PROXY_SESSION_PER_ACCOUNT=true

# Optional legacy split-auth form. Leave blank when credentials are in NITTER_PROXY.
NITTER_PROXY_AUTH=

# Optional nitter-proxy service. Leave blank for direct X/Twitter API requests.
NITTER_API_PROXY=

# Docker default. For local non-Docker runs, use ./sessions.jsonl or omit this.
NITTER_SESSIONS_FILE=/config/sessions.jsonl

# Conservative account-protection defaults. Scale volume by adding more
# authorized sessions, not by hammering each account harder.
NITTER_MAX_CONCURRENT_REQS=1
NITTER_MIN_REQUEST_INTERVAL_MS=3000
NITTER_ERROR_COOLDOWN_MS=60000
NITTER_RATE_LIMIT_REMAINING_BUFFER=10
